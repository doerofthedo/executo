{
    auto_https off
}

executo.local:80 {
    encode zstd gzip
    log {
        format filter {
            wrap console
            fields {
                request>headers delete
                resp_headers delete
                duration delete
                size delete
            }
        }
    }

    log_skip /favicon.ico
    log_skip /favicon.svg
    log_skip /robots.txt
    log_skip /vite-hmr*
    log_skip /@vite*
    log_skip /assets/*

    handle /api/* {
        reverse_proxy backend:80
    }

    handle /assets/manifest.json {
        respond 404
    }

    handle /assets/* {
        root * /srv/public
        file_server
    }

    redir /mail /mail/ 308

    handle /mail* {
        reverse_proxy mailpit:8025
    }

    handle {
        reverse_proxy node:80
    }
}

http://executo.local:8080 {
    handle /assets/manifest.json {
        respond 404
    }

    handle {
        reverse_proxy backend:80
    }
}
